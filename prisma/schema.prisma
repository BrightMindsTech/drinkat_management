generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // Runtime uses WASM (`@prisma/client/wasm` in src/lib/prisma.ts), not Linux .so binaries on Cloudflare.
  binaryTargets   = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String   @id @default(cuid())
  name      String   @unique // MEU, HU, Airport Street
  /// WGS84 — set by admin for geofence (nullable until configured)
  latitude   Float?
  longitude  Float?
  /// Default ~20m; server uses slight tolerance around this
  geofenceRadiusM Float @default(25)
  /// `airport` = night shift uses Fri 17:30–Sat 02:30 instead of 17:00–02:00 on that evening
  shiftProfile    String   @default("default")
  createdAt DateTime @default(now())
  users     User[]
  employees Employee[]
  checklists Checklist[]
  checklistAssignments ChecklistAssignment[]
  qcSubmissions QcSubmission[]
  salaryCopies SalaryCopy[]
  employeeTransfersFrom EmployeeTransfer[] @relation("FromBranch")
  employeeTransfersTo   EmployeeTransfer[] @relation("ToBranch")
  managementFormSubmissions ManagementFormSubmission[]
  timeClockEntries TimeClockEntry[]
  awaySessions AwaySession[]
  weeklyRatings WeeklyRating[]
}

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  employees Employee[]
  formTemplateAssignments FormTemplateDepartment[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          String    // owner | qc | staff | manager
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  employee      Employee?
  /// ISO consent timestamps for location / push (GDPR-style opt-in)
  locationConsentAt DateTime?
  pushConsentAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  pushSubscriptions PushSubscription[]
  inboxNotifications InboxNotification[]
  chatParticipants  ChatParticipant[]
  chatMessagesSent  ChatMessage[]       @relation("ChatMessageSender")
  chatTypingStates  ChatTypingState[]
}

/// Single-row keys for infrequent jobs (e.g. throttled chat retention) without external schedulers.
model AppCronWatermark {
  key       String   @id
  lastRunAt DateTime
}

/// Direct 1:1 (`kind=direct`, two participants) or group (`kind=group`, multiple members). Messages older than ~24h are purged (throttled); empty direct threads are removed; empty group threads are kept.
model ChatThread {
  id           String              @id @default(cuid())
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  /// `direct` | `group`
  kind         String              @default("direct")
  title        String?
  participants ChatParticipant[]
  messages     ChatMessage[]
  typingStates ChatTypingState[]
}

model ChatParticipant {
  threadId   String
  userId     String
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt   DateTime   @default(now())
  lastReadAt DateTime?

  @@id([threadId, userId])
  @@index([userId])
}

model ChatMessage {
  id           String     @id @default(cuid())
  threadId     String
  thread       ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUserId String
  sender       User       @relation("ChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  body         String
  createdAt    DateTime   @default(now())

  @@index([threadId, createdAt])
}

/// Ephemeral typing indicator; stale rows removed by retention job.
model ChatTypingState {
  threadId  String
  userId    String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime   @updatedAt

  @@id([threadId, userId])
}

model Employee {
  id          String    @id @default(cuid())
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  name        String
  contact     String?   // phone number (kept as-is for compatibility)
  salaryAmount Float?
  residentialArea String?
  shiftTime   String?
  idCardPhotoPath String?
  idCardFrontPhotoPath String?
  idCardBackPhotoPath String?
  role        String    // staff | qc | manager
  /// full_time (default) | part_time — part-time staff are expected ≥15 distinct clock-in days per calendar month
  employmentType String @default("full_time")
  status      String    @default("active") // active | on_leave | terminated
  advanceLimit Float?   // max JOD advance allowed, null = no limit
  leaveBalanceDays Int? // annual entitlement remaining
  joinDate    DateTime?  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Direct reporting line (manager -> staff/qc). V1 supports direct reports only.
  reportsToEmployeeId String?
  reportsToEmployee   Employee? @relation("EmployeeReports", fields: [reportsToEmployeeId], references: [id], onDelete: SetNull)
  directReports       Employee[] @relation("EmployeeReports")
  advances    Advance[]
  assignments ChecklistAssignment[]
  qcSubmissions QcSubmission[]
  salaryCopies SalaryCopy[]
  leaveRequests LeaveRequest[]
  documents   EmployeeDocument[]
  performanceReviews PerformanceReview[]
  transfers   EmployeeTransfer[]
  managementFormSubmissions ManagementFormSubmission[]
  formTemplateAssignments FormTemplateEmployee[]
  shiftDefinitionId String?
  shiftDefinition   ShiftDefinition? @relation(fields: [shiftDefinitionId], references: [id], onDelete: SetNull)
  timeClockEntries TimeClockEntry[]
  awaySessions     AwaySession[]
  weeklyRatingsAsRater   WeeklyRating[] @relation("WeeklyRatingRater")
  weeklyRatingsAsTarget  WeeklyRating[] @relation("WeeklyRatingTarget")
}

/// One directional weekly score (0–100). Unique per rater + target + ISO week (Monday key YYYY-MM-DD in APP_TIMEZONE).
model WeeklyRating {
  id               String   @id @default(cuid())
  raterEmployeeId  String
  rater            Employee @relation("WeeklyRatingRater", fields: [raterEmployeeId], references: [id], onDelete: Cascade)
  targetEmployeeId String
  target           Employee @relation("WeeklyRatingTarget", fields: [targetEmployeeId], references: [id], onDelete: Cascade)
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  weekStartKey     String
  score            Int
  reason           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([raterEmployeeId, targetEmployeeId, weekStartKey])
  @@index([branchId, weekStartKey])
  @@index([targetEmployeeId, weekStartKey])
}

/// Morning / Night work shifts (local minutes in APP_TIMEZONE, see lib/shifts.ts)
model ShiftDefinition {
  id              String   @id @default(cuid())
  key             String   @unique // morning | night
  name            String
  /// 0–1439 minutes from midnight (start of shift)
  startMinute     Int
  /// 0–1439 end minute; if crossesMidnight, this is end on the *next* calendar day morning
  endMinute       Int
  crossesMidnight Boolean  @default(false)
  createdAt       DateTime @default(now())
  employees       Employee[]
}

model TimeClockEntry {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clockInAt    DateTime
  clockOutAt   DateTime?
  clockInLat   Float?
  clockInLng   Float?
  clockOutLat  Float?
  clockOutLng  Float?
  clockOutReason String? // manual | away_timer_expired | force_hr_manager | force_hr_owner
  createdAt    DateTime  @default(now())

  @@index([employeeId, clockOutAt])
}

/// Temporary leave from branch geofence (break / bathroom / other) with a timer
model AwaySession {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  kind        String   // break | bathroom | other
  otherNote   String?
  startedAt   DateTime @default(now())
  endsAt      DateTime
  status      String   @default("active") // active | completed | canceled | expired_processed

  @@index([employeeId, status])
  @@index([endsAt, status])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Web Push endpoint URL, or FCM registration token stored as pseudo-URL `fcm:TOKEN`
  endpoint  String
  /// Web Push auth/p256dh JSON; null for FCM-only rows
  keysJson  String?
  provider  String   // web | fcm | apns
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, endpoint])
}

/// In-app + audit trail for manager/owner (push complement)
model InboxNotification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String    // time_clock
  title       String
  body        String
  dataJson    String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, readAt])
}

model LeaveRequest {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  type        String    // sick | annual | other
  status      String    @default("pending") // pending | approved | denied
  note        String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())
}

model EmployeeDocument {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  filePath    String
  title       String    // e.g. "Contract"
  documentType String   @default("other") // criminal_record | contract | certificate | id_copy | other
  documentNumber String?
  issuedOn    DateTime?
  expiresOn   DateTime?
  createdAt   DateTime  @default(now())
}

model PerformanceReview {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedAt    DateTime
  rating        Int       // 1-5
  notes         String?
  reviewedById  String?   // owner user id
  createdAt     DateTime  @default(now())
}

model EmployeeTransfer {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fromBranchId  String
  fromBranch    Branch    @relation("FromBranch", fields: [fromBranchId], references: [id], onDelete: Cascade)
  toBranchId    String
  toBranch      Branch    @relation("ToBranch", fields: [toBranchId], references: [id], onDelete: Cascade)
  transferredAt DateTime  @default(now())
  transferredById String?  // owner user id
}

model Advance {
  id          String      @id @default(cuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount      Float
  note        String?
  status      String   @default("pending") // pending | approved | denied
  periodMonth String?     // YYYY-MM for deduction reporting
  requestedAt DateTime   @default(now())
  decidedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Checklist {
  id            String    @id @default(cuid())
  name          String
  branchId      String?   // null = global
  branch        Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdById   String?   // user id of owner or qc
  repeatsDaily  Boolean   @default(false)
  deadlineTime  String    @default("23:59") // "HH:mm" e.g. "18:00" - time of day deadline applies
  items         ChecklistItem[]
  assignments   ChecklistAssignment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChecklistItem {
  id           String    @id @default(cuid())
  checklistId  String
  checklist    Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  title        String    // e.g. "Opening – fridge temp"
  sortOrder    Int       @default(0)
  createdAt    DateTime @default(now())
  submissionPhotos SubmissionPhoto[]
}

model ChecklistAssignment {
  id           String    @id @default(cuid())
  checklistId  String
  checklist    Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  submissions  QcSubmission[]
}

model QcSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   ChecklistAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  submittedAt  DateTime         @default(now())
  status       String   @default("pending") // pending | approved | denied
  rating       Int?             // e.g. 1-5
  comments     String?
  reviewedAt   DateTime?
  isLate       Boolean          @default(false)
  lateNote     String?          // auto-generated when submitted after deadline
  photos       SubmissionPhoto[]
}

model SubmissionPhoto {
  id            String       @id @default(cuid())
  submissionId  String
  submission    QcSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  itemId        String?       // optional: link to checklist item
  item          ChecklistItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  filePath      String       // path under uploads/
  createdAt     DateTime     @default(now())
}

model SalaryCopy {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  periodMonth String   // YYYY-MM
  amount      Float
  source      String?  // "upload" | "manual"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, periodMonth])
}

/// QC / HR / operations forms (replaces Google Forms workflows in-app).
model ManagementFormTemplate {
  id           String   @id @default(cuid())
  category     String   // qc | marketing | kitchen | cash
  title        String
  description  String?
  fieldsJson   String   // JSON array of field defs
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  submissions  ManagementFormSubmission[]
  departmentAssignments FormTemplateDepartment[]
  employeeAssignments FormTemplateEmployee[]
}

model FormTemplateEmployee {
  templateId String
  employeeId String
  template   ManagementFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  employee   Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([templateId, employeeId])
}

model FormTemplateDepartment {
  templateId   String
  departmentId String
  template     ManagementFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([templateId, departmentId])
}

model ManagementFormSubmission {
  id           String   @id @default(cuid())
  templateId   String
  template     ManagementFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  answersJson  String
  status       String   @default("submitted") // submitted | pending (legacy) | approved | denied (legacy)
  rating       Int?
  comments     String?
  reviewedAt   DateTime?
  reviewedById String?
  submittedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([templateId])
  @@index([employeeId])
  @@index([branchId])
}
