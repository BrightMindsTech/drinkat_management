{
  "name": "drinkat-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/patch-prisma-workers.mjs",
    "build": "next build",
    "dev": "next dev -H 0.0.0.0",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:remote": "tsx prisma/seed-d1-remote.ts",
    "db:seed:local": "tsx prisma/seed-d1-local.ts",
    "db:studio": "prisma studio",
    "db:d1:migrate:local": "wrangler d1 execute drinkat-management --local --file=./prisma/migrations/0001_init.sql",
    "db:d1:migrate:remote": "wrangler d1 execute drinkat-management --remote --file=./prisma/migrations/0001_init.sql",
    "db:d1:migrate:form-status:local": "wrangler d1 execute drinkat-management --local --file=./prisma/migrations/0004_form_status_submitted.sql",
    "db:d1:migrate:form-status:remote": "wrangler d1 execute drinkat-management --remote --file=./prisma/migrations/0004_form_status_submitted.sql",
    "db:d1:migrate:time-clock:local": "wrangler d1 execute drinkat-management --local --file=./prisma/migrations/0005_time_clock_shifts.sql",
    "db:d1:migrate:time-clock:remote": "wrangler d1 execute drinkat-management --remote --file=./prisma/migrations/0005_time_clock_shifts.sql",
    "db:d1:migrate:shift-profile:local": "wrangler d1 execute drinkat-management --local --file=./prisma/migrations/0006_shift_times_airport_profile.sql",
    "db:d1:migrate:shift-profile:remote": "wrangler d1 execute drinkat-management --remote --file=./prisma/migrations/0006_shift_times_airport_profile.sql",
    "db:d1:migrate:weekly-ratings:local": "wrangler d1 execute drinkat-management --local --file=./prisma/migrations/0007_weekly_ratings.sql",
    "db:d1:migrate:weekly-ratings:remote": "wrangler d1 execute drinkat-management --remote --file=./prisma/migrations/0007_weekly_ratings.sql",
    "db:d1:migrate:chat:local": "wrangler d1 execute drinkat-management --local --file=./prisma/migrations/0008_chat.sql",
    "db:d1:migrate:chat:remote": "wrangler d1 execute drinkat-management --remote --file=./prisma/migrations/0008_chat.sql",
    "db:d1:migrate:watermark:local": "wrangler d1 execute drinkat-management --local --file=./prisma/migrations/0009_app_cron_watermark.sql",
    "db:d1:migrate:watermark:remote": "wrangler d1 execute drinkat-management --remote --file=./prisma/migrations/0009_app_cron_watermark.sql",
    "db:d1:migrate:employment-type:local": "wrangler d1 execute drinkat-management --local --file=./prisma/migrations/0010_employee_employment_type.sql",
    "db:d1:migrate:employment-type:remote": "wrangler d1 execute drinkat-management --remote --file=./prisma/migrations/0010_employee_employment_type.sql",
    "db:d1:migrate:time-clock:all:remote": "npm run db:d1:migrate:time-clock:remote && npm run db:d1:migrate:shift-profile:remote",
    "db:d1:migrate:time-clock:all:local": "npm run db:d1:migrate:time-clock:local && npm run db:d1:migrate:shift-profile:local",
    "db:migrate:sql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script --output prisma/migrations/0001_init.sql",
    "preview": "opennextjs-cloudflare build && node scripts/ensure-prisma-workerd.mjs && node scripts/patch-opennext-worker-cron.mjs && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && node scripts/ensure-prisma-workerd.mjs && node scripts/patch-opennext-worker-cron.mjs && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && node scripts/ensure-prisma-workerd.mjs && node scripts/patch-opennext-worker-cron.mjs && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cap:add:ios": "node node_modules/@capacitor/cli/bin/capacitor add ios",
    "cap:sync": "node node_modules/@capacitor/cli/bin/capacitor sync",
    "cap:ios": "node node_modules/@capacitor/cli/bin/capacitor open ios",
    "cap:run:ios": "node node_modules/@capacitor/cli/bin/capacitor run ios",
    "cap:ios:run": "node node_modules/@capacitor/cli/bin/capacitor run ios"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.0",
    "@capacitor/ios": "^7.4.0",
    "@capacitor/push-notifications": "^7.0.6",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "jose": "^5.10.0",
    "next": "^15.5.14",
    "next-auth": "^4.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.14.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.0",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@opennextjs/cloudflare": "^1.18.0",
    "@prisma/adapter-d1": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.78.0"
  }
}
