{
  "name": "drinkat-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/patch-prisma-workers.mjs",
    "build": "next build",
    "dev": "next dev -H 0.0.0.0",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:remote": "tsx prisma/seed-d1-remote.ts",
    "db:studio": "prisma studio",
    "db:d1:migrate:local": "wrangler d1 execute drinkat-management --local --file=./prisma/migrations/0001_init.sql",
    "db:d1:migrate:remote": "wrangler d1 execute drinkat-management --remote --file=./prisma/migrations/0001_init.sql",
    "db:migrate:sql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script --output prisma/migrations/0001_init.sql",
    "preview": "opennextjs-cloudflare build && node scripts/ensure-prisma-workerd.mjs && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && node scripts/ensure-prisma-workerd.mjs && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && node scripts/ensure-prisma-workerd.mjs && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "next": "^15.5.14",
    "next-auth": "^4.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@opennextjs/cloudflare": "^1.18.0",
    "@prisma/adapter-d1": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.78.0"
  }
}
